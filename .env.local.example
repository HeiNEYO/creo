# App (obligatoire pour reset mot de passe + lien magique)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — dans le dashboard : Authentication > URL Configuration
# - Site URL = NEXT_PUBLIC_APP_URL
# - Redirect URLs : inclure {NEXT_PUBLIC_APP_URL}/auth/callback (ex. http://localhost:3000/auth/callback)

# Supabase (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optionnel : actions admin / webhooks (ne jamais exposer au client)
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend (https://resend.com/api-keys)
RESEND_API_KEY=

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
