# Copier vers .env.local et remplir les valeurs.
# NEXT_PUBLIC_* sont exposées au navigateur — ne mets jamais de secret dedans.

# App (obligatoire pour reset mot de passe + liens magiques)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — Authentication > URL Configuration
# Site URL = NEXT_PUBLIC_APP_URL
# Redirect URLs : {NEXT_PUBLIC_APP_URL}/auth/callback
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optionnel : actions serveur uniquement (ne jamais exposer au client)
# Recommandé en prod : invitations équipe (`/invite/...`, aperçu inscription `?invite=`).
SUPABASE_SERVICE_ROLE_KEY=

# Emails autorisés (séparés par des virgules) pour /dashboard/admin/creo-intake
CREO_ADMIN_EMAILS=

# Stripe (https://dashboard.stripe.com/apikeys)
# Pour Connect (lier le compte vendeur) : activer Connect sur CE compte Stripe → https://dashboard.stripe.com/connect
# OAuth « compte Stripe existant » (Standard) : Dashboard Stripe → Connect → Paramètres de l’intégration → identifiant ca_…
# Ajoute aussi l’URL de redirection exacte : {NEXT_PUBLIC_APP_URL}/api/stripe/connect/oauth/callback
NEXT_PUBLIC_STRIPE_CONNECT_CLIENT_ID=
# Optionnel : secret dédié pour signer le state OAuth (sinon dérivé de STRIPE_SECRET_KEY)
STRIPE_CONNECT_OAUTH_SECRET=
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe → Développeurs → Webhooks → endpoint vers /api/webhooks/stripe
# Événements recommandés (abonnement plateforme + Connect + ventes pages) :
# checkout.session.completed, customer.subscription.updated, customer.subscription.deleted, account.updated
# (checkout.session.completed enregistre aussi les commandes « page » + e-mail reçu acheteur si Resend OK)
# Abonnement plateforme CRÉO (mode subscription, EUR) — Stripe → Produits → 3 produits × 2 tarifs (mensuel + annuel)
# Mensuels : 27 €, 57 €, 97 €. Annuels fixes : 260 €, 550 €, 930 € / an (Creator, Pro, Agency)
STRIPE_PRICE_CREATOR_MONTHLY=
STRIPE_PRICE_CREATOR_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_AGENCY_MONTHLY=
STRIPE_PRICE_AGENCY_YEARLY=
# Rétrocompat : si défini seul, sert de prix mensuel Creator (migration depuis l’ancienne variable unique)
STRIPE_PRICE_CREATOR=
# Portail client (factures, carte, résiliation) : Stripe → Paramètres → Facturation → Portail client
# Optionnel : commission plateforme sur les paiements des pages checkout (0–100, nombre entier)
STRIPE_APPLICATION_FEE_PERCENT=0
# Optionnel : plafond d’e-mails « broadcast » (campagnes) par workspace et par mois civil (0 = illimité)
EMAIL_MONTHLY_BROADCAST_CAP=0
# Sous-domaines par workspace : ex. creo-saas.vercel.app → https://{slug}.creo-saas.vercel.app/
# En local, laisser vide ou utiliser un domaine de test avec DNS wildcard.
NEXT_PUBLIC_ROOT_DOMAIN=

# Supabase Auth : activer « Confirm email » pour un compte renforcé (recommandé en prod).

# Resend (https://resend.com/api-keys)
RESEND_API_KEY=
# Domaine vérifié chez Resend (ex. onboarding@resend.dev en test)
RESEND_FROM=
# E-mail de bienvenue (1× / compte) : migration profiles.welcome_email_sent_at
# Pixel sur /p/… : migration get_public_page (meta_pixel_id depuis workspace.settings)

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
