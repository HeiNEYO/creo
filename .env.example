# Copier vers .env.local et remplir les valeurs.
# NEXT_PUBLIC_* sont exposées au navigateur — ne mets jamais de secret dedans.

# App (obligatoire pour reset mot de passe + liens magiques)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — Authentication > URL Configuration
# Site URL = NEXT_PUBLIC_APP_URL
# Redirect URLs : {NEXT_PUBLIC_APP_URL}/auth/callback
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optionnel : actions serveur uniquement (ne jamais exposer au client)
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend (https://resend.com/api-keys)
RESEND_API_KEY=

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
